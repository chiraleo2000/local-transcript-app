# HuggingFace token (required for gated models like Typhoon Whisper)
HF_TOKEN=hf_xxxxx

# OpenVINO device: GPU, CPU, or AUTO
OV_DEVICE=GPU

# Project-local model/cache directories. In Docker these map to /app/models/*.
APP_MODEL_ROOT=./models
HF_HOME=./models/hf_cache
HF_HUB_CACHE=./models/hf_cache/hub
HF_HUB_OFFLINE=0
HUGGINGFACE_HUB_CACHE=./models/hf_cache/hub
TORCH_HOME=./models/torch
OV_CACHE_DIR=./models/ov_cache

# Keep runtime logs clean while still showing errors.
APP_SUPPRESS_WARNING_LOGS=true
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ASR runtime policy
# Strict 8 GB mode keeps only one ASR model resident on the GPU.
# On 8 GB-class GPUs, forced parallel mode is ignored by ASR_HARD_MEMORY_SAFE.
ASR_PARALLEL_MODE=auto
ASR_PARALLEL_MIN_VRAM_MB=12288
ASR_HARD_MEMORY_SAFE=true
ASR_8GB_CLASS_MAX_MB=9000
ASR_CLEAR_VRAM_AFTER_JOB=true
ASR_CLEAR_VRAM_BETWEEN_ENGINES=true
ASR_DEFAULT_ENGINES=Pathumma Whisper
ASR_CUDA_BATCH_SIZE=1
ASR_8GB_BATCH_SIZE=1
ASR_8GB_MAX_BATCH_SIZE=1
ASR_CUDA_MEMORY_FRACTION=0.90
ASR_CHUNK_LENGTH_S=30
ASR_8GB_CHUNK_LENGTH_S=20
ASR_8GB_MAX_CHUNK_LENGTH_S=20
ASR_8GB_RETRY_CHUNK_LENGTH_S=10
ASR_WORD_TIMESTAMPS_WITH_DIARIZATION=true
TYPHOON_WORD_TIMESTAMPS_ON_8GB=false
PATHUMMA_WORD_TIMESTAMPS_ON_8GB=false
ASR_ATTENTION_IMPLEMENTATION=sdpa
ASR_PRELOAD_MODE=eager

# Audio enhancement defaults: louder speech with capped gain to avoid clipping/noise blow-up.
AUDIO_ENHANCE_DEFAULT=false
AUDIO_ENHANCE_TARGET_PEAK_DB=-3.0
AUDIO_ENHANCE_MAX_GAIN_DB=10.0
AUDIO_ENHANCE_NOISE_REDUCTION=0.65

# Speaker diarization/preprocessing stays on CPU by default to reserve VRAM for ASR.
DIARIZATION_MODEL_ID=pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=cpu
DIARIZATION_CUDA_MIN_VRAM_MB=12288

# Optional local LLM correction after transcript generation
# Recommended for strict 8 GB transcription: keep the LLM unloaded or run it on CPU
# while ASR is active; use correction only after the transcript is generated.
LOCAL_LLM_PROVIDER=llamacpp
LLAMACPP_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
LOCAL_LLM_MODEL=typhoon2-8b-instruct-q4
LOCAL_LLM_MAX_TOKENS=4096
