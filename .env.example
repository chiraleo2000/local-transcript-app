# Local Transcript App — environment template
#
# For Docker GPU deploy, docker-compose.gpu.yml OVERRIDES these values.
# Edit .env for HF_TOKEN only; use compose for GPU runtime policy.
#
# Deploy:
#   docker compose -f docker-compose.gpu.yml build && docker compose -f docker-compose.gpu.yml up -d
#   GPU UI: http://localhost:7988  |  OpenVINO: http://localhost:7987
#
APP_VERSION=1.2.7
GRADIO_SERVER_PORT=7896
GRADIO_SERVER_NAME=0.0.0.0

# Minimum host floor: 4 CPU threads, 8 GB RAM (OpenVINO/CPU/DirectML).
# NVIDIA path still wants >= 8 GB VRAM. APP_CPU_THREADS=0 means auto-detect.
MIN_SYSTEM_RAM_MB=8192
MIN_CPU_THREADS=4
MIN_NVIDIA_VRAM_MB=8192
APP_CPU_THREADS=0

# Deploy backend for Deploy-Docker.bat / deploy/scripts/Deploy-Docker.ps1
# auto = NVIDIA Docker GPU if available, else OpenVINO
DEPLOY_BACKEND=auto
# CUDA container stack: latest (13.3) | cuda126 | cuda124
DEPLOY_CUDA_STACK=latest
# Set to 1 to publish GPU UI on 127.0.0.1:7988 only (WiFi-safe / behind nginx)
# DEPLOY_LOOPBACK=0

# Public access behind nginx / Cloudflare (see deploy/SETUP.md)
# GRADIO_ROOT_PATH=/transcript
# GRADIO_MAX_FILE_SIZE=512mb
# GRADIO_AUTH_USER=
# GRADIO_AUTH_PASSWORD=
# Shared UI + REST auth (SQLite at storage/users.db). Prefer this over GRADIO_AUTH_*.
APP_AUTH_ENABLED=true
APP_SEED_USER=chira
# Set a strong password in your local .env — never commit the real value.
# APP_SEED_PASSWORD=
# APP_AUTH_SECRET=
# APP_USERS_DB=storage/users.db
# APP_PUBLIC_BASE_URL=https://asrservice.demotoday.th

# Travel-proof hostname (Cloudflare Tunnel) — required by Setup-TravelTunnel.ps1
# Create tunnel in Zero Trust dashboard; public hostname -> http://host.docker.internal:7988
# CLOUDFLARE_TUNNEL_TOKEN=

HF_TOKEN=hf_xxxxx

# Optional: force backend selection (otherwise auto-detect)
# cuda | rocm | openvino | directml | cpu
#APP_FORCE_BACKEND=openvino

# OpenVINO device selection (GPU-first when Intel GPU is visible):
# - GPU (default): prefer Intel Arc / Core Ultra iGPU (falls back to CPU if absent)
# - AUTO: same as GPU (explicit GPU → NPU → CPU order)
# - GPU.0: force a specific OpenVINO GPU device id
# - NPU: force Intel NPU
# - CPU: force CPU
OV_DEVICE=GPU

# Project-local model/cache directories. In Docker these map to /app/models/*.
APP_MODEL_ROOT=./models
HF_HOME=./models/hf_cache
HF_HUB_CACHE=./models/hf_cache/hub
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
TRANSFORMERS_CACHE=./models/hf_cache/hub
APP_AUTO_DOWNLOAD_MISSING_MODELS=false
APP_REQUIRE_DIARIZATION_MODELS=true
HUGGINGFACE_HUB_CACHE=./models/hf_cache/hub
TORCH_HOME=./models/torch
OV_CACHE_DIR=./models/ov_cache

# Keep runtime logs clean while still showing errors.
# IMPORTANT: keep this false so INFO progress logs (engine start/finish, window
# 1/N, batch=X) are visible in `docker compose logs -f` while a job runs.
APP_SUPPRESS_WARNING_LOGS=false
PYTHONUNBUFFERED=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
HF_HUB_DISABLE_TELEMETRY=1
GRADIO_ANALYTICS_ENABLED=false
GRADIO_TELEMETRY_ENABLED=false

# ASR runtime policy
# parallel mode runs both ASR engines concurrently on the same GPU. On 8 GB-class
# cards this requires ASR_ALLOW_8GB_PARALLEL=true; the engines auto-recover from
# CUDA OOM by halving batch size first, then dropping to batch=1 with chunked
# timestamps.
#
# On 8 GB GPUs, parallel mode causes CUDA driver OOM and corrupts the caching
# allocator (handles_.at INTERNAL ASSERT FAILED). Sequential mode at batch=8
# fully saturates the GPU with one model at a time and is faster overall.
ASR_PARALLEL_MODE=sequential
ASR_PARALLEL_MIN_VRAM_MB=12288
ASR_ALLOW_8GB_PARALLEL=false
ASR_HARD_MEMORY_SAFE=true
ASR_8GB_CLASS_MAX_MB=9000
ASR_CLEAR_VRAM_AFTER_JOB=false
ASR_CLEAR_VRAM_BETWEEN_ENGINES=false
ASR_CLEAR_VRAM_ON_MEDIA_CHANGE=false
ASR_UNLOAD_FOR_DIARIZATION=true
ASR_KEEP_PRELOADED=false
ASR_PRELOAD_MODE=lazy
AUDIO_ENHANCE_DEFAULT=false
AUDIO_ENHANCE_WHEN_DIARIZATION=false
AUDIO_STAGE_TO_TMP=true
TYPHOON_WORD_TIMESTAMPS_ON_8GB=false
DIARIZATION_DEVICE=cuda
DIARIZATION_PRELOAD_DEVICE=cuda
DIARIZATION_PRELOAD_MODE=lazy
DIARIZATION_KEEP_PRELOADED=true
DIARIZATION_MULTI_SAMPLE=false
ASR_SUPPRESS_HALLUCINATIONS=true
ASR_CONDITION_ON_PREVIOUS_TEXT=false
ASR_TEMPERATURE=0.0
ASR_COMPRESSION_RATIO_THRESHOLD=1.8
ASR_LOGPROB_THRESHOLD=-0.8
ASR_NO_SPEECH_THRESHOLD=0.5
ASR_DEFAULT_ENGINES=Auto
# quality = Typhoon for Thai/English; fast = Pathumma for Thai speed on 8 GB
ASR_AUTO_POLICY=quality
ASR_CUDA_BATCH_SIZE=4
ASR_8GB_BATCH_SIZE=4
ASR_8GB_MAX_BATCH_SIZE=4
ASR_BATCH_DURATION_CAP=true
ASR_CUDA_MEMORY_FRACTION=0.75
ASR_CHUNK_LENGTH_S=300
ASR_8GB_CHUNK_LENGTH_S=90
ASR_8GB_MAX_CHUNK_LENGTH_S=90
ASR_8GB_RETRY_CHUNK_LENGTH_S=15
ASR_WORD_TIMESTAMPS_WITH_DIARIZATION=true
TYPHOON_WORD_TIMESTAMPS_ON_8GB=false
PATHUMMA_WORD_TIMESTAMPS_ON_8GB=true
ASR_ATTENTION_IMPLEMENTATION=sdpa
ASR_PRELOAD_MODE=lazy
ASR_KEEP_PRELOADED=false

# Quality-first profile (default). Use balanced only for emergency low-VRAM / OOM recovery.
# Explicit .env values always override profile defaults.
ASR_QUALITY_PROFILE=high
# Adaptive beams/merge per job:
#   short audio (<20 min) → up to 10 min wall time
#   medium (20 min–1 h) → up to 30 min
#   1 h+ → min(30 min, audio_duration / 4)
# Docker GPU deploy overrides these for production (see docker-compose.gpu.yml).
# Enterprise policy: VRAM 0.92, batch=1, multi-sample off, adaptive perf off.
ASR_ADAPTIVE_PERFORMANCE=false
ASR_TARGET_SHORT_MAX_S=600
ASR_TARGET_LONG_MAX_S=0
ASR_TARGET_MEDIUM_AUDIO_S=1200
ASR_TARGET_LONG_AUDIO_S=3600
ASR_TARGET_RT_RATIO_LONG=2
ASR_CUDA_MEMORY_FRACTION=0.75
ASR_CUDA_MEMORY_FRACTION_MAX=0.90
ASR_CUDA_BATCH_SIZE=1
ASR_NUM_BEAMS=4
ASR_NUM_BEAMS_MAX=4
ASR_NUM_BEAMS_MIN=4
ASR_FAST_MODE=true
ASR_CLEAR_VRAM_ON_MEDIA_CHANGE=false
ASR_8GB_ALLOW_LARGE_CHUNKS=true
ASR_MIN_CHUNKED_DURATION_S=120
ASR_LONG_FORM_WINDOW_S=300
ASR_LONG_FORM_OVERLAP_S=45
DIARIZATION_TRANSCRIPT_MERGE_GAP_S=1.0
DIARIZATION_ACCURACY_MODE=true
DIARIZATION_MULTI_SAMPLE=false
DIARIZATION_MULTI_SAMPLE_PASSES=0
DIARIZATION_PREPROCESS_SR=44100
DIARIZATION_SEGMENT_S=300
DIARIZATION_SEGMENT_OVERLAP_S=60
DIARIZATION_MAX_ASR_WINDOW_S=300
# Model IDs (Hugging Face — accept terms and cache locally)
PATHUMMA_MODEL_ID=nectec/Pathumma-whisper-th-large-v3
TYPHOON_MODEL_ID=typhoon-ai/typhoon-whisper-large-v3

# Browser UI limits — prevent Chrome "Aw, Snap! Out of Memory" on large files.
UI_PREVIEW_MAX_MB=32
UI_PREVIEW_MAX_DURATION_S=300
UI_TRANSCRIPT_MAX_CHARS=100000
UI_TRANSCRIPT_MAX_LINES=500
# Max GPU pipeline jobs at once (VRAM). On 6–8 GB keep 1 — parallel ASR+diar will OOM.
# "4 parallel" = up to 4 accepted/queued jobs; GPU phases serialize.
# Extra users wait in Gradio/API queue. Restart app after changing (semaphore fixed at import).
UI_MAX_CONCURRENT_JOBS=1
# Max concurrent CUDA ASR inferences (1 on 8 GB — shared Whisper pipeline).
ASR_MAX_CONCURRENT_INFERENCE=1
# Keep ASR models loaded on cancel; Cancel still clears CUDA cache for the next queued job.
ASR_UNLOAD_ON_CANCEL=false
UI_CANCEL_FREES_GPU_FOR_QUEUE=true
UI_CANCEL_JOIN_TIMEOUT_S=120
# Max Gradio transcribe handlers (queued users); does not add GPU load by itself. Use 2–4 for workstations.
UI_GRADIO_TRANSCRIBE_CONCURRENCY=4
# REST headless job queue cap (POST /api/jobs)
API_MAX_QUEUED_JOBS=4
# Gradio queue capacity (rejected when full)
UI_QUEUE_MAX_SIZE=16
# Previous transcripts: prefer logged-in user; IP filter is legacy fallback
UI_HISTORY_PER_CLIENT_IP=true
# How often the UI refreshes stopwatch/phase during a job (seconds)
UI_PROGRESS_POLL_S=1.0

# Audio enhancement — louder speech, stronger background suppression (CPU-only).
AUDIO_ENHANCE_DEFAULT=true
AUDIO_ENHANCE_WHEN_DIARIZATION=true
AUDIO_ENHANCE_TARGET_PEAK_DB=-0.5
AUDIO_ENHANCE_MAX_GAIN_DB=24
AUDIO_ENHANCE_NOISE_REDUCTION=0.96
AUDIO_ENHANCE_LOUDNORM_I=-12
AUDIO_ENHANCE_ATEMPO=0.92
AUDIO_ENHANCE_NOISE_PROFILE=leading
AUDIO_ENHANCE_NOISE_PROFILE_SECONDS=0.75
AUDIO_ENHANCE_GATE_THRESHOLD_DB=-42
AUDIO_ENHANCE_GATE_RATIO=6
AUDIO_ENHANCE_COMPRESSOR_THRESHOLD_DB=-18
AUDIO_ENHANCE_COMPRESSOR_RATIO=4
AUDIO_ENHANCE_LIMITER_THRESHOLD_DB=-0.5

# Speaker diarization — GPU profile (OpenVINO compose uses DIARIZATION_DEVICE=cpu).
DIARIZATION_MODEL_ID=pyannote/speaker-diarization-community-1
DIARIZATION_DEVICE=cuda
DIARIZATION_GPU_CO_RESIDENT=false
DIARIZATION_PRELOAD_MODE=lazy
DIARIZATION_PRELOAD_DEVICE=cuda
DIARIZATION_KEEP_PRELOADED=true
DIARIZATION_CUDA_MIN_VRAM_MB=6000
DIARIZATION_CUDA_MIN_FREE_MB=768
DIARIZATION_CUDA_RUN_MIN_FREE_MB=512
DIARIZATION_ALLOW_8GB_CUDA=true
DIARIZATION_ACCURACY_MODE=true
DIARIZATION_MULTI_SAMPLE=false
DIARIZATION_SEGMENTATION_THRESHOLD=0.38
DIARIZATION_CLUSTERING_THRESHOLD=0.40
DIARIZATION_TRANSCRIPT_MERGE_GAP_S=0.0
ASR_UNLOAD_FOR_DIARIZATION=true
# Optional manual overrides (>= 0). Leave unset for adaptive short-clip tuning.
#DIARIZATION_SEGMENTATION_THRESHOLD=0.42
#DIARIZATION_MIN_DURATION_OFF=0.10
#DIARIZATION_CLUSTERING_THRESHOLD=0.60
#DIARIZATION_MIN_CLUSTER_SIZE=6

# Job history manifests are stored under storage/jobs/ and listed in the UI
# "Previous transcripts" panel. Refresh the page while a job runs to recover progress.
