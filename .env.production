# Production / installer runtime configuration.
#
# This file ships INSIDE the GUI installer payload. It deliberately contains
# NO Hugging Face token: gated models (Typhoon Whisper, pyannote diarization)
# are pre-cached into ./models/ at build time on a maintainer machine that
# holds the token, then the cache is bundled with the installer. End-user
# runtimes only read from the local cache and never authenticate.
#
# Do not commit secrets here.

# --- Hugging Face cache: strictly offline, cache-first -----------------------
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
APP_AUTO_DOWNLOAD_MISSING_MODELS=false

# Project-local model/cache directories (relative to install dir).
APP_MODEL_ROOT=./models
HF_HOME=./models/hf_cache
HF_HUB_CACHE=./models/hf_cache/hub
HUGGINGFACE_HUB_CACHE=./models/hf_cache/hub
TORCH_HOME=./models/torch
OV_CACHE_DIR=./models/ov_cache

# --- Launcher: always direct (no Docker) -------------------------------------
APP_FORCE_DIRECT=1
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7896

# --- Hardware policy (equal-priority parity) ---------------------------------
# Acceleration backend is auto-selected across NVIDIA CUDA, AMD ROCm,
# Intel OpenVINO (NPU/GPU), Windows DirectML, and CPU fallback. Override
# with APP_FORCE_BACKEND=cuda|rocm|openvino|directml|cpu when troubleshooting.
#APP_FORCE_BACKEND=
OV_DEVICE=AUTO
MIN_NVIDIA_VRAM_MB=6000
MIN_SYSTEM_RAM_MB=16000

# --- Logging -----------------------------------------------------------------
APP_SUPPRESS_WARNING_LOGS=true
PYTHONUNBUFFERED=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- ASR runtime policy ------------------------------------------------------
ASR_PARALLEL_MODE=auto
ASR_PARALLEL_MIN_VRAM_MB=12288
ASR_ALLOW_8GB_PARALLEL=false
ASR_HARD_MEMORY_SAFE=true
ASR_8GB_CLASS_MAX_MB=9000
ASR_CLEAR_VRAM_AFTER_JOB=false
ASR_CLEAR_VRAM_BETWEEN_ENGINES=false
ASR_DEFAULT_ENGINES=Pathumma Whisper
ASR_CUDA_BATCH_SIZE=8
ASR_8GB_BATCH_SIZE=1
ASR_8GB_MAX_BATCH_SIZE=1
ASR_CUDA_MEMORY_FRACTION=0.90
ASR_CHUNK_LENGTH_S=180
ASR_8GB_CHUNK_LENGTH_S=30
ASR_8GB_MAX_CHUNK_LENGTH_S=30
ASR_8GB_RETRY_CHUNK_LENGTH_S=10
ASR_WORD_TIMESTAMPS_WITH_DIARIZATION=true
TYPHOON_WORD_TIMESTAMPS_ON_8GB=false
PATHUMMA_WORD_TIMESTAMPS_ON_8GB=false
ASR_LONG_FORM_MIN_DURATION_S=300
ASR_LONG_FORM_WINDOW_S=360
ASR_LONG_FORM_OVERLAP_S=30
ASR_SUSPICIOUS_FIRST_TS_S=60
ASR_TIMESTAMP_AUDIO_END_TOLERANCE_S=30
ASR_MAX_CHUNK_CHARS_PER_SECOND=35
ASR_ATTENTION_IMPLEMENTATION=sdpa
ASR_PRELOAD_MODE=eager

# --- Audio enhancement -------------------------------------------------------
AUDIO_ENHANCE_DEFAULT=true
AUDIO_ENHANCE_WHEN_DIARIZATION=true
AUDIO_ENHANCE_TARGET_PEAK_DB=-0.5
AUDIO_ENHANCE_MAX_GAIN_DB=24
AUDIO_ENHANCE_NOISE_REDUCTION=0.96
AUDIO_ENHANCE_LOUDNORM_I=-12
AUDIO_ENHANCE_NOISE_PROFILE=leading
AUDIO_ENHANCE_NOISE_PROFILE_SECONDS=0.75
AUDIO_ENHANCE_GATE_THRESHOLD_DB=-42
AUDIO_ENHANCE_GATE_RATIO=6
AUDIO_ENHANCE_COMPRESSOR_THRESHOLD_DB=-18
AUDIO_ENHANCE_COMPRESSOR_RATIO=4
AUDIO_ENHANCE_LIMITER_THRESHOLD_DB=-0.5

# --- Diarization -------------------------------------------------------------
DIARIZATION_MODEL_ID=pyannote/speaker-diarization-community-1
DIARIZATION_DEVICE=cpu
DIARIZATION_CUDA_MIN_VRAM_MB=12288
DIARIZATION_CUDA_MIN_FREE_MB=1024
DIARIZATION_ALLOW_8GB_CUDA=false
DIARIZATION_PREPROCESS_SR=16000
DIARIZATION_NOISE_REDUCTION=0.0
