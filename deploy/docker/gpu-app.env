# Shared NVIDIA GPU runtime (fast diarization + accuracy locks).
# Secrets stay in repo-root .env (GRADIO_AUTH_*, HF_TOKEN, etc.).

APP_VERSION=1.2.7
GRADIO_SERVER_PORT=7896
GRADIO_SERVER_NAME=0.0.0.0
PYTHONPATH=/app
PYTHONUNBUFFERED=1
APP_SUPPRESS_WARNING_LOGS=false
TOKENIZERS_PARALLELISM=false
MIN_SYSTEM_RAM_MB=8192
MIN_CPU_THREADS=4
MIN_NVIDIA_VRAM_MB=8192
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,max_split_size_mb:128
CUDA_MODULE_LOADING=LAZY
NVIDIA_REQUIRE_CUDA=cuda>=12.4
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
CUDA_AUTO_RESTART=1
APP_MODEL_ROOT=/app/models
HF_HOME=/app/models/hf_cache
HF_HUB_CACHE=/app/models/hf_cache/hub
HUGGINGFACE_HUB_CACHE=/app/models/hf_cache/hub
TORCH_HOME=/app/models/torch
OV_CACHE_DIR=/app/models/ov_cache
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
APP_AUTO_DOWNLOAD_MISSING_MODELS=false
APP_REQUIRE_DIARIZATION_MODELS=true
DIARIZATION_DEVICE=cuda
DIARIZATION_REQUIRE_CUDA=1
DIARIZATION_ALLOW_8GB_CUDA=true
DIARIZATION_GPU_CO_RESIDENT=false
DIARIZATION_PRELOAD_DEVICE=cuda
DIARIZATION_PRELOAD_MODE=eager
DIARIZATION_KEEP_PRELOADED=true
DIARIZATION_CUDA_MIN_VRAM_MB=6000
DIARIZATION_CUDA_MIN_FREE_MB=768
DIARIZATION_CUDA_RUN_MIN_FREE_MB=512
DIARIZATION_MODEL_ID=pyannote/speaker-diarization-community-1
DIARIZATION_ACCURACY_MODE=true
DIARIZATION_EXACT_NUM_SPEAKERS=false
DIARIZATION_MULTI_SAMPLE=false
DIARIZATION_MULTI_SAMPLE_PASSES=0
DIARIZATION_CHUNK_ALIGN_MIN_OVERLAP_S=0.75
DIARIZATION_SEGMENTATION_THRESHOLD=0.31
DIARIZATION_CLUSTERING_THRESHOLD=0.38
DIARIZATION_MIN_DURATION_OFF=0.02
DIARIZATION_LOCK_PARAMS=true
DIARIZATION_PREPROCESS_SR=16000
DIARIZATION_SEGMENT_S=1800
DIARIZATION_SEGMENT_OVERLAP_S=30
DIARIZATION_SEGMENT_LONG_AUDIO=true
DIARIZATION_SEGMENT_LONG_AUDIO_MIN_S=7200
DIARIZATION_OVERCLUSTER_EXTRA=0
DIARIZATION_CENTROID_MERGE_THRESHOLD=0
DIARIZATION_VBX_FA=0.30
DIARIZATION_VBX_FB=0.8
DIARIZATION_BRIEF_RESCUE_MAX_SPAN_S=8
DIARIZATION_INTRO_RECOVERY=false
DIARIZATION_INTRO_RECOVERY_SPAN_S=360
DIARIZATION_MAX_ASR_WINDOW_S=300
DIARIZATION_REFINE_AFTER_SEGMENTED=false
DIARIZATION_MEGA_TURN_RETRY_S=22
DIARIZATION_MEGA_TURN_MAX_REFINES=0
DIARIZATION_MEGA_TURN_MIN_AUDIO_S=0
DIARIZATION_SHORT_AUDIO_MEGA_REFINE=false
DIARIZATION_DOMINANCE_RETRY_RATIO=0.68
DIARIZATION_TRANSCRIPT_MERGE_GAP_S=0.0
DIARIZATION_ASSIGN_TURN_MERGE_GAP_S=0.0
DIARIZATION_ASSIGN_IMBALANCE_RATIO=0.70
DIARIZATION_MIN_OVERLAP_S=0.06
DIARIZATION_SPLIT_MIN_TURN_S=1.5
DIARIZATION_NOISE_REDUCTION=0.0
ASR_UNLOAD_FOR_DIARIZATION=true
ASR_KEEP_PRELOADED=true
ASR_PRELOAD_MODE=eager
ASR_CLEAR_VRAM_ON_MEDIA_CHANGE=false
ASR_CLEAR_VRAM_AFTER_JOB=false
ASR_CLEAR_VRAM_BETWEEN_ENGINES=false
ASR_DEFAULT_ENGINES=Auto
ASR_AUTO_POLICY=quality
ASR_QUALITY_PROFILE=high
ASR_ADAPTIVE_PERFORMANCE=false
ASR_TARGET_SHORT_MAX_S=600
ASR_TARGET_LONG_MAX_S=0
ASR_TARGET_MEDIUM_AUDIO_S=1200
ASR_TARGET_LONG_AUDIO_S=3600
ASR_TARGET_RT_RATIO_LONG=2
ASR_BUDGET_SEC_PER_TURN=4.5
ASR_DIAR_OVERHEAD_BASE_S=50
ASR_DIAR_OVERHEAD_PER_MIN_S=1.0
ASR_DIAR_WINDOWED_FAST=false
ASR_DIAR_WINDOWED_MIN_DURATION_S=999999
ASR_DIAR_WINDOWED_TURN_THRESHOLD=999999
ASR_DIAR_WINDOWED_WINDOW_S=300
ASR_DIAR_WINDOWED_LONG_ONLY_S=999999
ASR_ATTENTION_IMPLEMENTATION=sdpa
ASR_HARD_MEMORY_SAFE=true
ASR_8GB_QUALITY_MODE=true
MIN_NVIDIA_VRAM_MB=6000
ASR_8GB_CLASS_MAX_MB=9000
ASR_PARALLEL_MODE=sequential
ASR_PARALLEL_MIN_VRAM_MB=12288
ASR_ALLOW_8GB_PARALLEL=false
ASR_MAX_CONCURRENT_INFERENCE=1
ASR_CUDA_BATCH_SIZE=1
ASR_8GB_BATCH_SIZE=1
ASR_8GB_MAX_BATCH_SIZE=1
ASR_BATCH_MIN_FREE_MB=1536
ASR_CUDA_MEMORY_FRACTION=0.92
ASR_CUDA_MEMORY_FRACTION_MAX=0.92
ASR_CO_RESIDENT_MIN_FREE_MB=512
ASR_NUM_BEAMS=4
ASR_NUM_BEAMS_MAX=4
ASR_NUM_BEAMS_MIN=4
ASR_SUPPRESS_HALLUCINATIONS=true
ASR_REJECT_HALLUCINATED_TURNS=true
ASR_CONDITION_ON_PREVIOUS_TEXT=false
ASR_TEMPERATURE=0.0,0.2
ASR_COMPRESSION_RATIO_THRESHOLD=2.4
ASR_LOGPROB_THRESHOLD=-0.5
ASR_NO_SPEECH_THRESHOLD=0.6
ASR_NO_REPEAT_NGRAM_SIZE=8
ASR_REPETITION_PENALTY=1.0
ASR_CHUNK_LENGTH_S=30
ASR_8GB_CHUNK_LENGTH_S=30
ASR_8GB_MAX_CHUNK_LENGTH_S=30
ASR_8GB_RETRY_CHUNK_LENGTH_S=15
ASR_MIN_CHUNKED_DURATION_S=90
ASR_LONG_FORM_MIN_DURATION_S=600
ASR_LONG_FORM_WINDOW_S=300
ASR_LONG_FORM_OVERLAP_S=60
ASR_WORD_TIMESTAMPS_WITH_DIARIZATION=false
TYPHOON_WORD_TIMESTAMPS_ON_8GB=false
PATHUMMA_WORD_TIMESTAMPS_ON_8GB=false
ASR_TURN_GUIDED=true
ASR_TURN_USE_DIAR_TIMESTAMPS=true
ASR_TURN_GUIDED_MAX_DURATION_S=86400
ASR_TURN_GUIDED_MAX_TURN_S=28
ASR_TURN_GUIDED_MERGE_GAP_S=0.35
ASR_TURN_GUIDED_MIN_TURN_S=0.2
ASR_TURN_BOUNDARY_TRIM_S=0.0
ASR_TURN_BOUNDARY_MARGIN_S=0.04
ASR_TURN_PAD_S=0.18
ASR_TURN_OUTPUT_MERGE_GAP_S=1.5
ASR_CLEANUP_THAI_SPACING=true
ASR_8GB_STREAM_MIN_DURATION_S=240
ASR_SUSPICIOUS_FIRST_TS_S=60
ASR_TIMESTAMP_AUDIO_END_TOLERANCE_S=30
ASR_MAX_CHUNK_CHARS_PER_SECOND=35
ASR_UNLOAD_ON_CANCEL=false
ASR_FAST_MODE=true
AUDIO_STAGE_TO_TMP=true
AUDIO_ENHANCE_ADAPTIVE=false
AUDIO_ENHANCE_USE_GPU=false
AUDIO_ENHANCE_DEFAULT=false
AUDIO_ENHANCE_WHEN_DIARIZATION=false
AUDIO_ENHANCE_ASR_ONLY=true
AUDIO_ENHANCE_NOISE_REDUCTION=0.35
AUDIO_ENHANCE_LOUDNORM_I=-14
AUDIO_ENHANCE_ATEMPO=1.0
UI_PREVIEW_MAX_MB=32
UI_PREVIEW_MAX_DURATION_S=300
UI_TRANSCRIPT_MAX_CHARS=100000
UI_TRANSCRIPT_MAX_LINES=500
UI_MAX_CONCURRENT_JOBS=1
UI_GRADIO_TRANSCRIBE_CONCURRENCY=4
UI_QUEUE_MAX_SIZE=16
UI_HISTORY_PER_CLIENT_IP=true
UI_CANCEL_FREES_GPU_FOR_QUEUE=true
UI_CANCEL_JOIN_TIMEOUT_S=120
