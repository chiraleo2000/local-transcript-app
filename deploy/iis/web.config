<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy → Local Transcript App GPU Docker (http://127.0.0.1:7988)

  Prerequisites: URL Rewrite + Application Request Routing (ARR), proxy enabled,
  WebSocket Protocol feature enabled. See deploy/iis/README.md.
-->
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- ~512 MB audio uploads -->
        <requestLimits maxAllowedContentLength="536870912" />
      </requestFiltering>
    </security>
    <proxy enabled="true" preserveHostHeader="true" />
    <rewrite>
      <rules>
        <rule name="LocalTranscriptApp Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:7988/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>
      </rules>
      <outboundRules>
        <preConditions>
          <preCondition name="IsHtmlResponse">
            <add input="{RESPONSE_CONTENT_TYPE}" pattern="^text/html" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    <webSocket enabled="true" />
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
  <system.web>
    <httpRuntime maxRequestLength="524288" executionTimeout="3600" />
  </system.web>
</configuration>
