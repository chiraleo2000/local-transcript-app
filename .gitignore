storage/
config/

# Release binaries / offline packs (large; do not commit)
release/**/*.exe
release/**/*.zip
release/**/*.zip.*
release/**/_stage/
debug-*.log

# Local runtime caches (never commit)
.cache/
.nv/
intel/
coverage.xml
.coverage
htmlcov/

